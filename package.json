{
  "name": "taller-code-analyzer-agent",
  "version": "1.0.0",
  "description": "AI-powered code analysis CLI using OpenRouter",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cza": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "start": "node dist/cli/index.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.0.1",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.5",
    "openai": "^4.86.2",
    "ora": "^8.2.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/pdf-parse": "^1.1.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
